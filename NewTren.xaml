<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TRAIN.NewPage1"
             xmlns:viewModels="clr-namespace:TRAIN.ViewModels"
             Title="Создание тренировки"
             BackgroundColor="#0A0A0A"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <!-- Современная цветовая палитра -->
        <Color x:Key="PrimaryBlack">#0A0A0A</Color>
        <Color x:Key="SecondaryBlack">#1E1E1E</Color>
        <Color x:Key="CardBlack">#2D2D2D</Color>
        <Color x:Key="AccentBlue">#4A90E2</Color>
        <Color x:Key="AccentGreen">#2E7D32</Color>
        <Color x:Key="AccentRed">#CF6679</Color>
        <Color x:Key="AccentYellow">#FFD60A</Color>
        <Color x:Key="TextPrimary">#FFFFFF</Color>
        <Color x:Key="TextSecondary">#B0B0B0</Color>
        <Color x:Key="TextTertiary">#3A3A3C</Color>

        <!-- Тени -->
        <Shadow x:Key="CardShadow"
                Brush="#50000000"
                Offset="0,4"
                Radius="12"
                Opacity="0.3"/>

        <!-- Стили для Entry -->
        <Style TargetType="Entry">
            <Setter Property="BackgroundColor" Value="{StaticResource CardBlack}" />
            <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
            <Setter Property="PlaceholderColor" Value="{StaticResource TextSecondary}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="HeightRequest" Value="50" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <!-- Стиль для Button -->
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="BackgroundColor" Value="{StaticResource AccentBlue}" />
            <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="HeightRequest" Value="50" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <!-- Стиль для Label заголовков -->
        <Style TargetType="Label" x:Key="SectionTitle">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
            <Setter Property="Margin" Value="0,15,0,8" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="*, Auto">
        <!-- Фон -->
        <Grid>
            <Grid BackgroundColor="{StaticResource PrimaryBlack}" />

            <!-- Декоративные элементы -->
            <Ellipse 
                Fill="#252525"
                WidthRequest="500"
                HeightRequest="500"
                HorizontalOptions="End"
                VerticalOptions="Start"
                Margin="100,-200,0,0"
                Opacity="0.2" />
            <Ellipse 
                Fill="{StaticResource AccentGreen}"
                WidthRequest="300"
                HeightRequest="300"
                HorizontalOptions="Start"
                VerticalOptions="End"
                Margin="0,0,0,-100"
                Opacity="0.1" />
            <Ellipse 
                Fill="{StaticResource AccentBlue}"
                WidthRequest="200"
                HeightRequest="200"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Margin="0,150,0,0"
                Opacity="0.05" />
        </Grid>

        <!-- Основной контент -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="15" Padding="20">

                <!-- Заголовок с иконкой -->
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,10">
                    <HorizontalStackLayout Grid.Column="0" Spacing="12">
                        <Label Text="💪" 
                               FontSize="32"
                               TextColor="{StaticResource AccentGreen}"
                               VerticalOptions="Center"/>
                        <Label Text="НОВАЯ ТРЕНИРОВКА"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <Border Grid.Column="2"
                            BackgroundColor="{StaticResource CardBlack}"
                            Stroke="{StaticResource TextTertiary}"
                            StrokeThickness="0.5"
                            StrokeShape="RoundRectangle 15"
                            Padding="10,6">
                        <Label Text="{Binding Goals.Count, StringFormat='{0} целей'}"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="12"/>
                    </Border>
                </Grid>

                <!-- Карточка основной информации -->
                <Border BackgroundColor="{StaticResource SecondaryBlack}"
                        StrokeShape="RoundRectangle 20"
                        Padding="20"
                        Margin="0,5"
                        Shadow="{StaticResource CardShadow}">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Основная информация"
                               Style="{StaticResource SectionTitle}"
                               Margin="0,0,0,5"/>

                        <!-- Название тренировки -->
                        <Border BackgroundColor="{StaticResource CardBlack}"
                                StrokeShape="RoundRectangle 12"
                                Padding="15,0"
                                HeightRequest="50">
                            <Entry Placeholder="Название тренировки (например, Баскетбол)" 
                                   Text="{Binding TrainingName}"
                                   BackgroundColor="Transparent"
                                   TextColor="{StaticResource TextPrimary}"
                                   PlaceholderColor="{StaticResource TextSecondary}"
                                   FontSize="15"
                                   VerticalOptions="Center"/>
                        </Border>

                        <!-- Дата и время -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <!-- Дата -->
                            <Border Grid.Column="0"
                                    BackgroundColor="{StaticResource CardBlack}"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="12,0"
                                    HeightRequest="50">
                                <Grid ColumnDefinitions="Auto,*">
                                    <Label Grid.Column="0" 
                                           Text="📅" 
                                           FontSize="16" 
                                           VerticalOptions="Center"
                                           Margin="0,0,8,0"/>
                                    <Entry Grid.Column="1"
                                           Placeholder="MM.dd"
                                           Text="{Binding Date}"
                                           BackgroundColor="Transparent"
                                           TextColor="{StaticResource TextPrimary}"
                                           PlaceholderColor="{StaticResource TextSecondary}"
                                           FontSize="15"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </Border>

                            <!-- Время -->
                            <Border Grid.Column="1"
                                    BackgroundColor="{StaticResource CardBlack}"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="12,0"
                                    HeightRequest="50">
                                <Grid ColumnDefinitions="Auto,*">
                                    <Label Grid.Column="0" 
                                           Text="⏰" 
                                           FontSize="16" 
                                           VerticalOptions="Center"
                                           Margin="0,0,8,0"/>
                                    <Entry Grid.Column="1"
                                           Placeholder="**:**"
                                           Text="{Binding Time}"
                                           BackgroundColor="Transparent"
                                           TextColor="{StaticResource TextPrimary}"
                                           PlaceholderColor="{StaticResource TextSecondary}"
                                           FontSize="15"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Карточка целей -->
                <Border BackgroundColor="{StaticResource SecondaryBlack}"
                        StrokeShape="RoundRectangle 20"
                        Padding="20"
                        Shadow="{StaticResource CardShadow}">
                    <VerticalStackLayout Spacing="15">

                        <!-- Заголовок с счетчиком -->
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="🎯"
                                   FontSize="16"
                                   TextColor="{StaticResource AccentBlue}"/>
                            <Label Text="ЦЕЛИ ТРЕНИРОВКИ"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   CharacterSpacing="1"/>
                        </HorizontalStackLayout>

                        <!-- Добавление цели -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <Border Grid.Column="0"
                                    BackgroundColor="{StaticResource CardBlack}"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="15,0"
                                    HeightRequest="50">
                                <Entry Placeholder="Введите новую цель"
                                       Text="{Binding NewGoal}"
                                       BackgroundColor="Transparent"
                                       TextColor="{StaticResource TextPrimary}"
                                       PlaceholderColor="{StaticResource TextSecondary}"
                                       FontSize="15"
                                       VerticalOptions="Center"/>
                            </Border>

                            <Border Grid.Column="1"
                                    BackgroundColor="{StaticResource AccentBlue}"
                                    StrokeShape="RoundRectangle 12"
                                    WidthRequest="50"
                                    HeightRequest="50">
                                <Button Text="+"
                                        Command="{Binding AddGoalCommand}"
                                        BackgroundColor="Transparent"
                                        TextColor="White"
                                        FontSize="24"
                                        FontAttributes="Bold"
                                        CornerRadius="12"
                                        Padding="0"/>
                            </Border>
                        </Grid>

                        <!-- Список целей -->
                        <CollectionView ItemsSource="{Binding Goals}"
                                       HeightRequest="200"
                                       Margin="0,5,0,0">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="{StaticResource CardBlack}"
                                            StrokeShape="RoundRectangle 12"
                                            Padding="15"
                                            Margin="0,4">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Label Grid.Column="0"
                                                   Text="•"
                                                   FontSize="20"
                                                   TextColor="{StaticResource AccentBlue}"
                                                   VerticalOptions="Center"
                                                   Margin="0,0,10,0"/>
                                            <Label Grid.Column="1"
                                                   Text="{Binding .}" 
                                                   TextColor="{StaticResource TextPrimary}"
                                                   FontSize="15"
                                                   VerticalOptions="Center"/>
                                            <Border Grid.Column="2"
                                                    BackgroundColor="Transparent"
                                                    Stroke="{StaticResource TextTertiary}"
                                                    StrokeThickness="0.5"
                                                    StrokeShape="RoundRectangle 8"
                                                    WidthRequest="36"
                                                    HeightRequest="36">
                                                <Button Text="✕"
                                                       BackgroundColor="Transparent"
                                                       TextColor="{StaticResource TextSecondary}"
                                                       FontSize="16"
                                                       CornerRadius="8"
                                                       Padding="0"
                                                       Command="{Binding BindingContext.RemoveGoalCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                       CommandParameter="{Binding .}"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.EmptyView>
                                <Border BackgroundColor="{StaticResource CardBlack}"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="30"
                                        Margin="0,10">
                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="🎯"
                                               FontSize="32"
                                               HorizontalOptions="Center"
                                               TextColor="{StaticResource TextSecondary}"/>
                                        <Label Text="Цели пока не добавлены"
                                               TextColor="{StaticResource TextSecondary}"
                                               FontSize="14"
                                               HorizontalOptions="Center"/>
                                        <Label Text="Нажмите + чтобы добавить цель"
                                               TextColor="{StaticResource TextSecondary}"
                                               FontSize="12"
                                               HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                </Border>
                            </CollectionView.EmptyView>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- Кнопка сохранения -->
                <Border BackgroundColor="{StaticResource AccentGreen}"
                        StrokeShape="RoundRectangle 25"
                        Margin="0,20,0,10"
                        Shadow="{StaticResource CardShadow}">
                    <Button Text="СОХРАНИТЬ ТРЕНИРОВКУ"
                            Command="{Binding SaveCommand}"
                            BackgroundColor="Transparent"
                            TextColor="White"
                            FontSize="18"
                            FontAttributes="Bold"
                            HeightRequest="55"
                            CornerRadius="25"/>
                </Border>

                <!-- Дополнительная информация -->
                <Label Text="Все тренировки сохраняются в вашем профиле"
                       TextColor="{StaticResource TextSecondary}"
                       FontSize="12"
                       HorizontalOptions="Center"
                       Margin="0,5,0,20"/>

                <!-- Отступ перед нижней панелью -->
                <BoxView HeightRequest="10" Color="Transparent"/>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Нижняя панель навигации -->
        <Border Grid.Row="1"
                BackgroundColor="{StaticResource CardBlack}"
                StrokeThickness="0.5"
                Stroke="{StaticResource TextTertiary}"
                StrokeShape="RoundRectangle 25"
                Padding="5"
                Margin="15,10,15,20"
                Shadow="{StaticResource CardShadow}">

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="5">

                <!-- Главная -->
                <Border Grid.Column="0"
                        BackgroundColor="Transparent"
                        Padding="0"
                        Margin="2">
                    <Button Text="🏠"
                            FontSize="22"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource TextSecondary}"
                            Padding="0"
                            HeightRequest="44"
                            CornerRadius="20"
                          Clicked="Button_Clicked_1"/>
                </Border>

                <!-- Новая тренировка (центральная, выделенная) -->
                <Border Grid.Column="1"
                        BackgroundColor="{StaticResource AccentGreen}"
                        StrokeShape="RoundRectangle 15"
                        Padding="0"
                        Margin="2"
                        HeightRequest="48">
                    <Button Text="➕"
                            FontSize="24"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource PrimaryBlack}"
                            Padding="0"
                            HeightRequest="48"
                            FontAttributes="Bold"
                            CornerRadius="15"
                          />
                </Border>

                <!-- Профиль -->
                <Border Grid.Column="2"
                        BackgroundColor="Transparent"
                        Padding="0"
                        Margin="2">
                    <Button Text="👤"
                            FontSize="22"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource TextSecondary}"
                            Padding="0"
                            HeightRequest="44"
                            CornerRadius="20"
                            FontAttributes="Bold"
                       Clicked="Button_Clicked"  />
                </Border>
            </Grid>
        </Border>
    </Grid>
</ContentPage>