<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TRAIN.MainPage"
             xmlns:viewModels="clr-namespace:TRAIN.ViewModels"
             Title="Главная"
             BackgroundColor="#0A0A0A"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.BindingContext>
        <viewModels:HomePageViewModel />
    </ContentPage.BindingContext>

    <ContentPage.Resources>
        <!-- Современная цветовая палитра -->
        <Color x:Key="PrimaryBlack">#0A0A0A</Color>
        <Color x:Key="SecondaryBlack">#1E1E1E</Color>
        <Color x:Key="CardBlack">#2D2D2D</Color>
        <Color x:Key="AccentBlue">#4A90E2</Color>
        <Color x:Key="AccentGreen">#2E7D32</Color>
        <Color x:Key="AccentRed">#CF6679</Color>
        <Color x:Key="AccentYellow">#FFD60A</Color>
        <Color x:Key="AccentGold">#FFD700</Color>
        <Color x:Key="TextPrimary">#FFFFFF</Color>
        <Color x:Key="TextSecondary">#B0B0B0</Color>
        <Color x:Key="TextTertiary">#3A3A3C</Color>

        <!-- Тени -->
        <Shadow x:Key="CardShadow"
                Brush="#50000000"
                Offset="0,4"
                Radius="12"
                Opacity="0.3"/>

        <!-- Стили для Label заголовков -->
        <Style TargetType="Label" x:Key="SectionTitle">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
            <Setter Property="Margin" Value="0,15,0,8" />
        </Style>

        <!-- Стиль для карточек статистики -->
        <Style TargetType="Border" x:Key="StatCardStyle">
            <Setter Property="BackgroundColor" Value="{StaticResource SecondaryBlack}" />
            <Setter Property="StrokeShape" Value="RoundRectangle 20" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Shadow" Value="{StaticResource CardShadow}" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="*, Auto">
        <!-- Фон с декоративными элементами -->
        <Grid>
            <Grid BackgroundColor="{StaticResource PrimaryBlack}" />

            <!-- Декоративные элементы -->
            <Ellipse 
                Fill="#252525"
                WidthRequest="500"
                HeightRequest="500"
                HorizontalOptions="End"
                VerticalOptions="Start"
                Margin="100,-200,0,0"
                Opacity="0.2" />
            <Ellipse 
                Fill="{StaticResource AccentGreen}"
                WidthRequest="300"
                HeightRequest="300"
                HorizontalOptions="Start"
                VerticalOptions="End"
                Margin="0,0,0,-100"
                Opacity="0.1" />
            <Ellipse 
                Fill="{StaticResource AccentGold}"
                WidthRequest="200"
                HeightRequest="200"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Margin="0,150,0,0"
                Opacity="0.05" />
        </Grid>

        <!-- Основной контент -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="15" Padding="20">

                <!-- Верхняя панель с приветствием и коинами -->
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,10,0,20">
                    <HorizontalStackLayout Grid.Column="0" Spacing="12">
                        <Label Text="🎯" 
                               FontSize="32"
                               TextColor="{StaticResource AccentYellow}"
                               VerticalOptions="Center"/>
                        <Label Text="МОИ ЦЕЛИ"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Блок с коинами -->
                    <Border Grid.Column="2"
                            BackgroundColor="{StaticResource CardBlack}"
                            Stroke="{StaticResource AccentGold}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 20"
                            Padding="15,8">
                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8">
                            <Label Grid.Column="0" 
                                   Text="🪙" 
                                   FontSize="20"
                                   TextColor="{StaticResource AccentGold}"/>
                            <Label Grid.Column="1" 
                                   Text="{Binding Coin}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource AccentGold}"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Карточка общей статистики целей -->
                <Border Style="{StaticResource StatCardStyle}">
                    <VerticalStackLayout Spacing="20">

                        <!-- Заголовок -->
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="📊"
                                   FontSize="16"
                                   TextColor="{StaticResource AccentBlue}"/>
                            <Label Text="СТАТИСТИКА ЦЕЛЕЙ"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   CharacterSpacing="1"/>
                        </HorizontalStackLayout>

                        <!-- Основной счетчик целей -->
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="15" Margin="0,5">

                            <!-- Всего целей -->
                            <Border Grid.Column="0"
                                    BackgroundColor="{StaticResource CardBlack}"
                                    StrokeShape="RoundRectangle 15"
                                    Padding="15,12">
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="🎯"
                                           FontSize="24"
                                           HorizontalOptions="Center"
                                           TextColor="{StaticResource AccentBlue}"/>
                                    <Label Text="{Binding Goal}"
                                           FontSize="28"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           TextColor="{StaticResource TextPrimary}"/>
                                    <Label Text="Всего"
                                           FontSize="12"
                                           HorizontalOptions="Center"
                                           TextColor="{StaticResource TextSecondary}"/>
                                </VerticalStackLayout>
                            </Border>

                            <!-- Выполнено -->
                            <Border Grid.Column="1"
                                    BackgroundColor="{StaticResource CardBlack}"
                                    StrokeShape="RoundRectangle 15"
                                    Padding="15,12">
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="✅"
                                           FontSize="24"
                                           HorizontalOptions="Center"
                                           TextColor="{StaticResource AccentGreen}"/>
                                    <Label Text="{Binding TrueGoal}"
                                           FontSize="28"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           TextColor="{StaticResource AccentGreen}"/>
                                   
                                </VerticalStackLayout>
                            </Border>

                            <!-- Не выполнено -->
                            <Border Grid.Column="2"
                                    BackgroundColor="{StaticResource CardBlack}"
                                    StrokeShape="RoundRectangle 15"
                                    Padding="15,12">
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="❌"
                                           FontSize="24"
                                           HorizontalOptions="Center"
                                           TextColor="{StaticResource AccentRed}"/>
                                    <Label Text="{Binding FalseGoal}"
                                           FontSize="28"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           TextColor="{StaticResource AccentRed}"/>
                                   
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Карточка прогресса целей -->
                <Border Style="{StaticResource StatCardStyle}">
                    <VerticalStackLayout Spacing="15">

                        <HorizontalStackLayout Spacing="8">
                            <Label Text="📈"
                                   FontSize="16"
                                   TextColor="{StaticResource AccentGreen}"/>
                            <Label Text="ПРОГРЕСС"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   CharacterSpacing="1"/>
                        </HorizontalStackLayout>

                        <!-- Прогресс выполнения -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                            <Border Grid.Column="0"
                                    BackgroundColor="{StaticResource CardBlack}"
                                    StrokeShape="RoundRectangle 15"
                                    Padding="15,20">
                                <VerticalStackLayout Spacing="10">
                                    <Label Text="Выполнено"
                                           FontSize="13"
                                           HorizontalOptions="Center"
                                           TextColor="{StaticResource TextSecondary}"/>

                                    <Label Text="{Binding TrueGoal}"
                                           FontSize="48"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           TextColor="{StaticResource AccentGreen}"/>

                                    <!-- Прогресс бар выполненных -->
                                    <Border BackgroundColor="{StaticResource TextTertiary}"
                                            StrokeShape="RoundRectangle 5"
                                            HeightRequest="8"
                                            Margin="0,5">
                                        <Border BackgroundColor="{StaticResource AccentGreen}"
                                                StrokeShape="RoundRectangle 5"
                                                WidthRequest="{Binding TrueGoal, StringFormat='{0}%'}"
                                                HeightRequest="8"
                                                HorizontalOptions="Start"/>
                                    </Border>
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1"
                                    BackgroundColor="{StaticResource CardBlack}"
                                    StrokeShape="RoundRectangle 15"
                                    Padding="15,20">
                                <VerticalStackLayout Spacing="10">
                                    <Label Text="Не выполнено"
                                           FontSize="13"
                                           HorizontalOptions="Center"
                                           TextColor="{StaticResource TextSecondary}"/>

                                    <Label Text="{Binding FalseGoal}"
                                           FontSize="48"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           TextColor="{StaticResource AccentRed}"/>

                                    <!-- Прогресс бар невыполненных -->
                                    <Border BackgroundColor="{StaticResource TextTertiary}"
                                            StrokeShape="RoundRectangle 5"
                                            HeightRequest="8"
                                            Margin="0,5">
                                        <Border BackgroundColor="{StaticResource AccentRed}"
                                                StrokeShape="RoundRectangle 5"
                                                WidthRequest="{Binding FalseGoal, StringFormat='{0}%'}"
                                                HeightRequest="8"
                                                HorizontalOptions="Start"/>
                                    </Border>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <!-- Общий прогресс -->
                        <Border BackgroundColor="{StaticResource CardBlack}"
                                StrokeShape="RoundRectangle 12"
                                Padding="15"
                                Margin="0,5">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Label Grid.Column="0" 
                                       Text="📊" 
                                       FontSize="16"
                                       Margin="0,0,10,0"/>
                                <Label Grid.Column="1" 
                                       Text="Общий прогресс" 
                                       TextColor="{StaticResource TextSecondary}"
                                       FontSize="14"/>
                                <Label Grid.Column="2">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding TrueGoal}"
                                                  FontSize="16"
                                                  FontAttributes="Bold"
                                                  TextColor="{StaticResource AccentGreen}"/>
                                            <Span Text=" / "
                                                  FontSize="14"
                                                  TextColor="{StaticResource TextSecondary}"/>
                                            <Span Text="{Binding Goal}"
                                                  FontSize="16"
                                                  FontAttributes="Bold"
                                                  TextColor="{StaticResource TextPrimary}"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!-- Карточка детальной информации -->
                <Border Style="{StaticResource StatCardStyle}">
                    <VerticalStackLayout Spacing="15">

                        <HorizontalStackLayout Spacing="8">
                            <Label Text="📋"
                                   FontSize="16"
                                   TextColor="{StaticResource AccentYellow}"/>
                            <Label Text="ДЕТАЛИ"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   CharacterSpacing="1"/>
                        </HorizontalStackLayout>

                        <!-- Список деталей -->
                        <VerticalStackLayout Spacing="10">

                            <!-- Всего целей -->
                            <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,5">
                                <Label Grid.Column="0" 
                                       Text="🎯" 
                                       FontSize="16" 
                                       Margin="0,0,10,0"/>
                                <Label Grid.Column="1" 
                                       Text="Всего целей" 
                                       TextColor="{StaticResource TextSecondary}"
                                       FontSize="15"/>
                                <Label Grid.Column="2" 
                                       Text="{Binding Goal}"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontSize="16"
                                       FontAttributes="Bold"/>
                            </Grid>

                            <BoxView HeightRequest="1" 
                                     Color="{StaticResource TextTertiary}" 
                                     Opacity="0.3"/>

                            <!-- Выполнено -->
                            <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,5">
                                <Label Grid.Column="0" 
                                       Text="✅" 
                                       FontSize="16" 
                                       Margin="0,0,10,0"/>
                                <Label Grid.Column="1" 
                                       Text="Выполнено" 
                                       TextColor="{StaticResource TextSecondary}"
                                       FontSize="15"/>
                                <Label Grid.Column="2" 
                                       Text="{Binding TrueGoal}"
                                       TextColor="{StaticResource AccentGreen}"
                                       FontSize="16"
                                       FontAttributes="Bold"/>
                            </Grid>

                            <BoxView HeightRequest="1" 
                                     Color="{StaticResource TextTertiary}" 
                                     Opacity="0.3"/>

                            <!-- Не выполнено -->
                            <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,5">
                                <Label Grid.Column="0" 
                                       Text="❌" 
                                       FontSize="16" 
                                       Margin="0,0,10,0"/>
                                <Label Grid.Column="1" 
                                       Text="Не выполнено" 
                                       TextColor="{StaticResource TextSecondary}"
                                       FontSize="15"/>
                                <Label Grid.Column="2" 
                                       Text="{Binding FalseGoal}"
                                       TextColor="{StaticResource AccentRed}"
                                       FontSize="16"
                                       FontAttributes="Bold"/>
                            </Grid>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Карточка с коинами -->
                <Border Style="{StaticResource StatCardStyle}">
                    <VerticalStackLayout Spacing="15">

                        <HorizontalStackLayout Spacing="8">
                            <Label Text="🪙"
                                   FontSize="16"
                                   TextColor="{StaticResource AccentGold}"/>
                            <Label Text="МОНЕТЫ"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   CharacterSpacing="1"/>
                        </HorizontalStackLayout>

                        <!-- Отображение коинов -->
                        <Border BackgroundColor="{StaticResource CardBlack}"
                                StrokeShape="RoundRectangle 15"
                                Padding="25"
                                Margin="0,5">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Label Grid.Column="0" 
                                       Text="🪙" 
                                       FontSize="32"
                                       TextColor="{StaticResource AccentGold}"
                                       VerticalOptions="Center"/>

                                <Label Grid.Column="1" 
                                       Text="{Binding Coin}"
                                       FontSize="48"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       TextColor="{StaticResource AccentGold}"/>

                                <Label Grid.Column="2" 
                                       Text="монет" 
                                       FontSize="18"
                                       TextColor="{StaticResource TextSecondary}"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- Дополнительная информация о коинах -->
                        <Label Text="Зарабатывайте монеты за выполнение целей"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="12"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Отступ перед нижней панелью -->
                <BoxView HeightRequest="10" Color="Transparent"/>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Нижняя панель навигации -->
        <Border Grid.Row="1"
                BackgroundColor="{StaticResource CardBlack}"
                StrokeThickness="0.5"
                Stroke="{StaticResource TextTertiary}"
                StrokeShape="RoundRectangle 25"
                Padding="5"
                Margin="15,10,15,20"
                Shadow="{StaticResource CardShadow}">

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="5">

                <!-- Главная (активная) -->
                <Border Grid.Column="0"
                        BackgroundColor="{StaticResource AccentGreen}"
                        StrokeShape="RoundRectangle 15"
                        Padding="0"
                        Margin="2"
                        HeightRequest="48">
                    <Button Text="🏠"
                            FontSize="22"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource PrimaryBlack}"
                            Padding="0"
                            HeightRequest="48"
                            CornerRadius="15"
                            FontAttributes="Bold"/>
                </Border>

                <!-- Новая тренировка -->
                <Border Grid.Column="1"
                        BackgroundColor="Transparent"
                        Padding="0"
                        Margin="2">
                    <Button Text="➕"
                            FontSize="24"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource TextSecondary}"
                            Padding="0"
                            HeightRequest="44"
                            CornerRadius="20"
                            Clicked="Button_Clicked_1"/>
                </Border>

                <!-- Профиль -->
                <Border Grid.Column="2"
                        BackgroundColor="Transparent"
                        Padding="0"
                        Margin="2">
                    <Button Text="👤"
                            FontSize="22"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource TextSecondary}"
                            Padding="0"
                            HeightRequest="44"
                            CornerRadius="20"
                            Clicked="Button_Clicked"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</ContentPage>